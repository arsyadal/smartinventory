<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — SmartInventory</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body { display: flex; min-height: 100vh; flex-direction: column; }
        .sidebar { width: 240px; min-height: 100vh; background: #1a2035; flex-shrink: 0; }
        .sidebar .nav-link { color: #adb5bd; padding: .6rem 1.2rem; border-radius: 6px; margin: 2px 8px; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { color: #fff; background: #0d6efd; }
        .sidebar .nav-link i { width: 20px; }
        .main-content { flex: 1; background: #f8f9fa; min-width: 0; }
        .card { border: none; box-shadow: 0 2px 8px rgba(0,0,0,.07); }
        .table thead th { background: #f1f3f5; font-size: .85rem; text-transform: uppercase; letter-spacing: .5px; }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
<div class="d-flex">
    @if (User.Identity?.IsAuthenticated == true)
    {
    <nav class="sidebar d-flex flex-column pt-3">
        <div class="px-3 mb-3">
            <span class="text-white fw-bold fs-5"><i class="bi bi-box-seam me-2"></i>SmartInventory</span>
        </div>
        <ul class="nav flex-column">
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                   asp-controller="Home" asp-action="Index">
                    <i class="bi bi-speedometer2 me-2"></i>Dashboard
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "active" : "")"
                   asp-controller="Product" asp-action="Index">
                    <i class="bi bi-box me-2"></i>Products
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Stock" ? "active" : "")"
                   asp-controller="Stock" asp-action="Index">
                    <i class="bi bi-archive me-2"></i>Stocks
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Supplier" ? "active" : "")"
                   asp-controller="Supplier" asp-action="Index">
                    <i class="bi bi-truck me-2"></i>Suppliers
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "PurchaseOrder" ? "active" : "")"
                   asp-controller="PurchaseOrder" asp-action="Index">
                    <i class="bi bi-receipt me-2"></i>Purchase Orders
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "PriceMonitor" ? "active" : "")"
                   asp-controller="PriceMonitor" asp-action="Index">
                    <i class="bi bi-graph-up me-2"></i>Price Monitor
                </a>
            </li>
        </ul>
        <div class="mt-auto px-3 pb-3">
            <small class="text-secondary"><i class="bi bi-person-circle me-1"></i>@User.Identity?.Name</small>
        </div>
    </nav>
    }

    <div class="flex-grow-1 main-content">
        @if (User.Identity?.IsAuthenticated == true)
        {
        <nav class="navbar navbar-light bg-white border-bottom px-4 py-2">
            <span class="navbar-brand text-muted fs-6 fw-semibold">@ViewData["Title"]</span>
            <div class="ms-auto">
                <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-box-arrow-right me-1"></i>Logout
                </a>
            </div>
        </nav>
        }

        <div class="p-4">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
