@model IEnumerable<SmartInventory.Application.DTOs.Products.ProductDto>
@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-semibold"><i class="bi bi-box me-2"></i>Products</h5>
    <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>New Product</a>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>SKU</th>
                    <th>Category</th>
                    <th class="text-end">Price</th>
                    <th class="text-end">Stock</th>
                    <th class="text-end">Min Stock</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td class="fw-semibold">@p.Name</td>
                    <td><code>@p.SKU</code></td>
                    <td><span class="badge bg-secondary">@p.Category</span></td>
                    <td class="text-end">Rp @p.Price.ToString("N0")</td>
                    <td class="text-end @(p.IsLowStock ? "text-danger fw-bold" : "")">@p.CurrentStock @(p.IsLowStock ? "⚠" : "")</td>
                    <td class="text-end text-muted">@p.MinStock</td>
                    <td>
                        @if (p.IsActive)
                        { <span class="badge bg-success">Active</span> }
                        else
                        { <span class="badge bg-secondary">Inactive</span> }
                    </td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-outline-secondary me-1"><i class="bi bi-eye"></i></a>
                        <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary me-1"><i class="bi bi-pencil"></i></a>
                        <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline"
                              onsubmit="return confirm('Delete @Html.Raw(p.Name.Replace("'","\'"))?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
