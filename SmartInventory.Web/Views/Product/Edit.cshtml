@model SmartInventory.Application.DTOs.Products.UpdateProductDto
@{
    ViewData["Title"] = "Edit Product";
    var productId = ViewBag.ProductId;
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card p-4">
            <h5 class="fw-semibold mb-4"><i class="bi bi-pencil me-2"></i>Edit Product</h5>

            <form asp-action="Edit" asp-route-id="@productId" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-semibold"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="SKU" class="form-label fw-semibold"></label>
                    <input asp-for="SKU" class="form-control" />
                    <span asp-validation-for="SKU" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Category" class="form-label fw-semibold"></label>
                    <input asp-for="Category" class="form-control" />
                    <span asp-validation-for="Category" class="text-danger small"></span>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Price" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text">Rp</span>
                            <input asp-for="Price" class="form-control" type="number" step="1000" min="0" />
                        </div>
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="MinStock" class="form-label fw-semibold"></label>
                        <input asp-for="MinStock" class="form-control" type="number" min="0" />
                        <span asp-validation-for="MinStock" class="text-danger small"></span>
                    </div>
                </div>
                <div class="mb-3 form-check">
                    <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                    <label asp-for="IsActive" class="form-check-label">Active</label>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
