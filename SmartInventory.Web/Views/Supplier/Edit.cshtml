@model SmartInventory.Application.DTOs.Suppliers.UpdateSupplierDto
@{
    ViewData["Title"] = "Edit Supplier";
    var supplierId = ViewBag.SupplierId;
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card p-4">
            <h5 class="fw-semibold mb-4"><i class="bi bi-pencil me-2"></i>Edit Supplier</h5>

            <form asp-action="Edit" asp-route-id="@supplierId" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-semibold"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Contact" class="form-label fw-semibold"></label>
                    <input asp-for="Contact" class="form-control" />
                    <span asp-validation-for="Contact" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Address" class="form-label fw-semibold"></label>
                    <textarea asp-for="Address" class="form-control" rows="2"></textarea>
                    <span asp-validation-for="Address" class="text-danger small"></span>
                </div>
                <div class="mb-4 form-check">
                    <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                    <label asp-for="IsActive" class="form-check-label">Active</label>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
