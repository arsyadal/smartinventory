@model SmartInventory.Application.DTOs.PurchaseOrders.PurchaseOrderDto
@using SmartInventory.Domain.Enums
@{
    ViewData["Title"] = $"PO #{Model.Id}";
    var badgeClass = Model.Status switch {
        PurchaseOrderStatus.Draft => "bg-secondary",
        PurchaseOrderStatus.Confirmed => "bg-warning text-dark",
        PurchaseOrderStatus.Received => "bg-success",
        PurchaseOrderStatus.Cancelled => "bg-danger",
        _ => "bg-secondary"
    };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-semibold"><i class="bi bi-receipt me-2"></i>Purchase Order #@Model.Id</h5>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

<div class="row g-3">
    <div class="col-lg-4">
        <div class="card p-3">
            <dl class="mb-0">
                <dt class="text-muted small">Supplier</dt>
                <dd class="fw-semibold">@Model.SupplierName</dd>
                <dt class="text-muted small">Status</dt>
                <dd><span class="badge @badgeClass">@Model.Status</span></dd>
                <dt class="text-muted small">Total Amount</dt>
                <dd class="fw-bold fs-5">Rp @Model.TotalAmount.ToString("N0")</dd>
                <dt class="text-muted small">Created</dt>
                <dd>@Model.CreatedAt.ToString("dd MMM yyyy HH:mm")</dd>
                @if (Model.ReceivedAt != null)
                {
                    <dt class="text-muted small">Received</dt>
                    <dd>@Model.ReceivedAt.Value.ToString("dd MMM yyyy HH:mm")</dd>
                }
            </dl>

            @if (Model.Status == PurchaseOrderStatus.Draft)
            {
                <form asp-action="Confirm" asp-route-id="@Model.Id" method="post" class="mt-3">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-warning w-100" onclick="return confirm('Confirm this order?')">
                        <i class="bi bi-check-lg me-1"></i>Confirm Order
                    </button>
                </form>
            }
            @if (Model.Status == PurchaseOrderStatus.Confirmed)
            {
                <form asp-action="Receive" asp-route-id="@Model.Id" method="post" class="mt-2">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-success w-100" onclick="return confirm('Mark as received? Stock will be auto-updated.')">
                        <i class="bi bi-box-arrow-in-down me-1"></i>Mark Received
                    </button>
                </form>
            }
            @if (Model.Status != PurchaseOrderStatus.Received && Model.Status != PurchaseOrderStatus.Cancelled)
            {
                <form asp-action="Cancel" asp-route-id="@Model.Id" method="post" class="mt-2">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-danger w-100" onclick="return confirm('Cancel this order?')">
                        <i class="bi bi-x-lg me-1"></i>Cancel Order
                    </button>
                </form>
            }
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card p-3">
            <h6 class="fw-semibold mb-3">Order Details</h6>
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th class="text-end">Qty</th>
                            <th class="text-end">Unit Price</th>
                            <th class="text-end">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var d in Model.Details)
                    {
                        <tr>
                            <td>@d.ProductName</td>
                            <td class="text-end">@d.Quantity</td>
                            <td class="text-end">Rp @d.UnitPrice.ToString("N0")</td>
                            <td class="text-end fw-semibold">Rp @d.Subtotal.ToString("N0")</td>
                        </tr>
                    }
                    </tbody>
                    <tfoot>
                        <tr class="table-active">
                            <th colspan="3" class="text-end">Total</th>
                            <th class="text-end">Rp @Model.TotalAmount.ToString("N0")</th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>
